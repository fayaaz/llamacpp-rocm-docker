{
    "$schema": "https://opencode.ai/config.json",
    "provider": {
        "llamacpp": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Llama.cpp",
            "options": {
                "baseURL": "http://Arches.local:8080/v1/",
                "toolParser": [
                    {
                        "type": "raw-function-call"
                    },
                    {
                        "type": "json"
                    }
                ]
            },
            "models": {
                "gemma-4-26b": {
                    "name": "gemma-4-26b",
                    "tool_call": true,
                    "limit": {
                        "context": 32768,
                        "output": 8192
                    }
                },
                "gemma-4-26b-hq": {
                    "name": "gemma-4-26b-hq",
                    "tool_call": true,
                    "limit": {
                        "context": 32768,
                        "output": 8192
                    }
                },
                "gemma-4-26b-64k": {
                    "name": "gemma-4-26b-64k",
                    "tool_call": true,
                    "limit": {
                        "context": 65536,
                        "output": 8192
                    }
                }
            }
        }
    }
}
